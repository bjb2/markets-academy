{
  "layers": [
    {
      "id": 0,
      "title": "Mental Models",
      "subtitle": "Price as information, time value, compounding. The epistemic frame for everything that follows.",
      "objective": "Explain in one breath why a free-floating price is the most information-dense signal in a complex society, and why compounding swamps almost every other variable.",
      "estWeeks": "1–2 weeks",
      "lessons": [
        "00.1-prices-as-information",
        "00.2-buyer-seller-clearing",
        "00.3-time-value-of-money",
        "00.4-compounding-rule-of-72",
        "00.5-inflation-real-vs-nominal",
        "00.6-risk-vs-uncertainty",
        "00.7-bernstein-primer",
        "00.8-capstone-essay"
      ]
    },
    {
      "id": 1,
      "title": "Macro & Monetary Plumbing",
      "subtitle": "The Fed, money, rates, business cycles. Trace a rate decision from statement to real economy.",
      "objective": "Trace a Fed rate decision from FOMC statement through bond market through equity market into the real economy.",
      "estWeeks": "3–4 weeks",
      "lessons": [
        "01.1-what-is-money",
        "01.2-fractional-reserve-banking",
        "01.3-the-federal-reserve",
        "01.4-fomc-open-market-ops",
        "01.5-yield-curve",
        "01.6-inflation-regimes",
        "01.7-business-cycle",
        "01.8-credit-cycle-marks",
        "01.9-sovereign-debt-deficit",
        "01.10-currency-fx-basics",
        "01.11-macro-voices-heterodox",
        "01.12-capstone-fomc-brief"
      ]
    },
    {
      "id": 2,
      "title": "Asset Classes & Valuation",
      "subtitle": "Stocks, bonds, ETFs, FX, commodities, crypto. Read a 10-K. Compute a yield-to-maturity.",
      "objective": "Given a 10-K, a bond prospectus, or an ETF fact sheet, identify the cash flows, the risks, the price, and whether the price looks reasonable.",
      "estWeeks": "3–4 weeks",
      "lessons": [
        "02.1-equity-as-claim",
        "02.2-dividends-buybacks-retained-earnings",
        "02.3-dcf-valuation",
        "02.4-multiples",
        "02.5-bonds",
        "02.6-duration-and-convexity",
        "02.7-credit-risk-and-spreads",
        "02.8-etfs-and-mutual-funds",
        "02.9-index-funds-passive",
        "02.10-commodities-fx-crypto"
      ]
    },
    {
      "id": 3,
      "title": "Portfolio Theory",
      "subtitle": "MPT, CAPM, factor models. Where the math behind our own sleeve gate comes from.",
      "objective": "Explain why the sleeve-diversification gate in paper-trading-longcall is the practical application of Markowitz, and where the model breaks.",
      "estWeeks": "2–3 weeks",
      "lessons": [
        "03.1-expected-return-variance-correlation",
        "03.2-diversification-math",
        "03.3-modern-portfolio-theory",
        "03.4-capm",
        "03.5-factor-models",
        "03.6-asset-allocation",
        "03.7-rebalancing",
        "03.8-sleeve-diversification"
      ]
    },
    {
      "id": 4,
      "title": "Market Microstructure",
      "subtitle": "Order books, market makers, slippage. What actually happens between 'buy' and the fill.",
      "objective": "Explain what really happens between hitting 'buy' and seeing the fill, and how much that costs you per round trip.",
      "estWeeks": "2–3 weeks",
      "lessons": [
        "04.1-order-books",
        "04.2-market-makers",
        "04.3-bid-ask-spread",
        "04.4-slippage-and-market-impact",
        "04.5-dark-pools-and-pfof",
        "04.6-hft-latency-colocation",
        "04.7-auctions"
      ]
    },
    {
      "id": 5,
      "title": "Behavioral Finance",
      "subtitle": "Heuristics, biases, prospect theory, bubbles. Why EMH is not the whole story.",
      "objective": "Identify five biases that have personally cost you money, with the trade or decision attached to each.",
      "estWeeks": "2 weeks",
      "lessons": []
    },
    {
      "id": 6,
      "title": "Active Strategy Archetypes",
      "subtitle": "Value, momentum, mean-reversion, carry, factor. Where each named investor sits in the taxonomy.",
      "objective": "Place every named investor (Buffett, Marks, Asness, Simons, Carver, Soros) into an archetype, and explain what they're trading and against whom.",
      "estWeeks": "3–4 weeks",
      "lessons": []
    },
    {
      "id": 7,
      "title": "Options & Derivatives",
      "subtitle": "Payoff diagrams, Greeks, IV, time decay, LEAPS. Bridges into the longcall sleeve.",
      "objective": "Draw the payoff diagram and Greeks profile for every position in the longcall sleeve from memory.",
      "estWeeks": "2–3 weeks",
      "lessons": ["07.1-call-put-basics"]
    },
    {
      "id": 8,
      "title": "Risk & Position Sizing",
      "subtitle": "Kelly, drawdowns, ruin risk, sequence-of-returns. The math behind why YOLO stacks lose.",
      "objective": "Explain the math that makes 'stacking dials degrades Sharpe' inevitable, not surprising.",
      "estWeeks": "2–3 weeks",
      "lessons": []
    },
    {
      "id": 9,
      "title": "Backtesting & Systematic",
      "subtitle": "Survivorship bias, look-ahead, regime dependence, walk-forward. Pyodide-powered.",
      "objective": "Take any strategy idea and backtest it correctly. Output an honest equity curve you'd stake real money on.",
      "estWeeks": "3–4 weeks",
      "lessons": []
    },
    {
      "id": 10,
      "title": "Epistemology of Markets",
      "subtitle": "EMH (Fama) vs behavioral (Shiller). Via negativa. Closes the loop with Layer 0.",
      "objective": "Hold the two contradictory positions (efficient / inefficient) simultaneously and explain when each is operative.",
      "estWeeks": "2 weeks",
      "lessons": []
    }
  ],
